#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/vercel/sandbox/node_modules/.pnpm/convex@1.31.4_react@18.3.1/node_modules/convex/bin/node_modules:/vercel/sandbox/node_modules/.pnpm/convex@1.31.4_react@18.3.1/node_modules/convex/node_modules:/vercel/sandbox/node_modules/.pnpm/convex@1.31.4_react@18.3.1/node_modules:/vercel/sandbox/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/vercel/sandbox/node_modules/.pnpm/convex@1.31.4_react@18.3.1/node_modules/convex/bin/node_modules:/vercel/sandbox/node_modules/.pnpm/convex@1.31.4_react@18.3.1/node_modules/convex/node_modules:/vercel/sandbox/node_modules/.pnpm/convex@1.31.4_react@18.3.1/node_modules:/vercel/sandbox/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/main.js" "$@"
else
  exec node  "$basedir/../../bin/main.js" "$@"
fi
